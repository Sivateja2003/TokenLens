# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.

# Backend API URL
VITE_API_BASE_URL=http://localhost:8000

# Firebase configuration variables (copy values from your Firebase Project Console)
# If not using Firebase, leave them as placeholder values.
VITE_FIREBASE_API_KEY="placeholder_api_key"
VITE_FIREBASE_AUTH_DOMAIN="placeholder_auth_domain"
VITE_FIREBASE_PROJECT_ID="placeholder_project_id"
VITE_FIREBASE_STORAGE_BUCKET="placeholder_storage_bucket"
VITE_FIREBASE_MESSAGING_SENDER_ID="placeholder_messaging_sender_id"
VITE_FIREBASE_APP_ID="placeholder_app_id"
